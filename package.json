{
  "name": "tutor-ai",
  "version": "0.1.0",
  "description": "AI辅导助手 - 图形化讲解数学题",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "build": {
    "appId": "com.tutorai.app",
    "productName": "TutorAI",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "build/icons/**",
      "package.json"
    ],
    "mac": {
      "icon": "build/icons/icon.png",
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icons/icon.png"
    },
    "linux": {
      "icon": "build/icons/icon.png"
    }
  },
  "keywords": [
    "electron",
    "react",
    "ai",
    "education"
  ],
  "author": "TutorAI Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "axios": "^1.6.2",
    "better-sqlite3": "^12.8.0",
    "electron-store": "^11.0.2",
    "gsap": "^3.14.2",
    "konva": "^9.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.10",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^4.1.0"
  }
}
